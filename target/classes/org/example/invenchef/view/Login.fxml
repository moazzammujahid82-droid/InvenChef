<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.invenchef.controller.LoginController"
      prefWidth="950"
      prefHeight="550"
      stylesheets="@style.css">

    <!-- ═══════════ LEFT PANEL (brand) ═══════════ -->
    <VBox alignment="CENTER"
          spacing="16"
          prefWidth="400"
          minWidth="360"
          styleClass="login-left-panel">
        <padding>
            <Insets top="50" right="40" bottom="50" left="40"/>
        </padding>

        <Label text="👨‍🍳" style="-fx-font-size: 70;"/>

        <Label text="InvenChef"                      styleClass="login-brand-title"/>
        <Label text="Smart Kitchen Inventory Manager" styleClass="login-brand-sub"/>

        <Region prefHeight="20"/>

        <Label text="✅  Track your ingredients"    styleClass="login-feature"/>
        <Label text="🍽  Discover matching recipes"  styleClass="login-feature"/>
        <Label text="⚠️  Get expiry alerts"           styleClass="login-feature"/>
    </VBox>

    <!-- ═══════════ RIGHT PANEL (form) ═══════════ -->
    <VBox alignment="CENTER"
          spacing="16"
          HBox.hgrow="ALWAYS"
          styleClass="login-right-panel">
        <padding>
            <Insets top="50" right="70" bottom="50" left="70"/>
        </padding>

        <Label text="Welcome Back!"           styleClass="login-title"/>
        <Label text="Sign in to your account" styleClass="login-subtitle"/>

        <Region prefHeight="6"/>

        <!-- Error label — hidden until login fails -->
        <Label fx:id="errorLabel"
               text=""
               visible="false"
               wrapText="true"
               maxWidth="Infinity"
               styleClass="login-error"/>

        <!-- Email -->
        <VBox spacing="5">
            <Label text="Email"    styleClass="login-field-label"/>
            <TextField fx:id="emailField"
                       promptText="Enter your email"
                       maxWidth="Infinity"
                       styleClass="login-field"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="5">
            <Label text="Password" styleClass="login-field-label"/>
            <PasswordField fx:id="passwordField"
                           promptText="Enter your password"
                           maxWidth="Infinity"
                           styleClass="login-field"/>
        </VBox>

        <!-- Remember me / Forgot password -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <CheckBox fx:id="rememberMe"
                      text="Remember me"
                      style="-fx-font-size: 12;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Forgot password?" styleClass="login-link"/>
        </HBox>

        <!-- Sign In -->
        <Button fx:id="loginBtn"
                text="Sign In"
                onAction="#handleLogin"
                maxWidth="Infinity"
                prefHeight="44"
                styleClass="login-btn"/>

        <!-- OR divider -->
        <HBox alignment="CENTER" spacing="10">
            <Region HBox.hgrow="ALWAYS"
                    style="-fx-border-color: #ddd; -fx-border-width: 0 0 1 0;"/>
            <Label text="OR" style="-fx-text-fill: #aaa; -fx-font-size: 12;"/>
            <Region HBox.hgrow="ALWAYS"
                    style="-fx-border-color: #ddd; -fx-border-width: 0 0 1 0;"/>
        </HBox>

        <!-- Register -->
        <Button fx:id="registerBtn"
                text="Create New Account"
                onAction="#handleRegister"
                maxWidth="Infinity"
                prefHeight="44"
                styleClass="register-btn"/>
    </VBox>

</HBox>
