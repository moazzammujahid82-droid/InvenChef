<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToHeight="true"
            fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: #f4f4f4;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.invenchef.controller.InventoryController">
    <HBox spacing="16" style="-fx-background-color: #f4f4f4;">
        <padding>
            <Insets top="16" right="16" bottom="16" left="16"/>
        </padding>

        <!-- Left Column: Form and Stats -->
        <VBox spacing="16" prefWidth="340" minWidth="300" maxWidth="380">

            <!-- Add Form Card -->
            <VBox spacing="12"
                  style="-fx-background-color: white;
                         -fx-background-radius: 8;
                         -fx-padding: 16;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,2);">

                <Label text="Add New Ingredient"
                       style="-fx-font-size: 24px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1b4332;"/>

                <VBox spacing="10">
                    <Label text="Ingredient Name"/>
                    <TextField fx:id="ingredientNameField" promptText="e.g. Milk"/>

                    <Label text="Quantity"/>
                    <TextField fx:id="quantityField" promptText="e.g. 2"/>

                    <Label text="Unit"/>
                    <ComboBox fx:id="unitCombo" maxWidth="Infinity"/>

                    <Label text="Category"/>
                    <ComboBox fx:id="categoryCombo" maxWidth="Infinity"/>

                    <Label text="Expiry Date"/>
                    <DatePicker fx:id="expiryDatePicker" maxWidth="Infinity"/>
                </VBox>

                <HBox spacing="10">
                    <Button fx:id="addIngredientBtn"
                            text="+ Add Ingredient"
                            prefHeight="45"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"
                            style="-fx-background-color: #40916c;
                                   -fx-background-radius: 8;
                                   -fx-text-fill: white;
                                   -fx-font-size: 14px;
                                   -fx-font-weight: bold;
                                   -fx-cursor: hand;"/>

                    <Button fx:id="clearFormBtn"
                            text="Clear Form"
                            prefHeight="45"
                            HBox.hgrow="ALWAYS"
                            maxWidth="Infinity"
                            style="-fx-background-color: #dddddd;
                                   -fx-background-radius: 8;
                                   -fx-font-size: 14px;
                                   -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Stats Card -->
            <VBox spacing="15"
                  style="-fx-background-color: white;
                         -fx-background-radius: 8;
                         -fx-padding: 16;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,2);">

                <Label text="Inventory Stats" style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

                <HBox spacing="8">
                    <VBox alignment="CENTER" prefWidth="72" prefHeight="70" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #40916c; -fx-background-radius: 8;">
                        <Label fx:id="totalLabel" text="0"
                               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox alignment="CENTER" prefWidth="72" prefHeight="70" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #52b788; -fx-background-radius: 8;">
                        <Label fx:id="freshLabel" text="0"
                               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox alignment="CENTER" prefWidth="72" prefHeight="70" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #fca311; -fx-background-radius: 8;">
                        <Label fx:id="expiringLabel" text="0"
                               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    </VBox>

                    <VBox alignment="CENTER" prefWidth="72" prefHeight="70" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #d62828; -fx-background-radius: 8;">
                        <Label fx:id="expiredLabel" text="0"
                               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>
            </VBox>
        </VBox>

        <!-- Right Column: Table Card -->
        <VBox spacing="15"
              HBox.hgrow="ALWAYS"
              minWidth="400"
              style="-fx-background-color: white;
                     -fx-background-radius: 8;
                     -fx-padding: 16;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,2);">

            <Label text="Current Inventory"
                   style="-fx-font-size: 24px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1b4332;"/>

            <HBox spacing="10">
                <Button fx:id="allTab" text="All" prefWidth="82" prefHeight="35"
                        style="-fx-background-color: #40916c; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>

                <Button fx:id="perishableTab" text="Perishable" prefWidth="92" prefHeight="35"
                        style="-fx-background-color: #e9ecef; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <Button fx:id="pantryTab" text="Pantry" prefWidth="82" prefHeight="35"
                        style="-fx-background-color: #e9ecef; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <Button fx:id="expiredTab" text="Expired" prefWidth="82" prefHeight="35"
                        style="-fx-background-color: #e9ecef; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </HBox>

            <TableView fx:id="inventoryTable"
                       VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-border-color: #eeeeee;">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Name" prefWidth="150" style="-fx-alignment: CENTER-LEFT;"/>
                    <TableColumn fx:id="qtyColumn" text="Qty" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="100" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="expiryColumn" text="Expiry" prefWidth="120" style="-fx-alignment: CENTER;"/>
                    <TableColumn fx:id="deleteColumn" text="Action" style="-fx-alignment: CENTER;"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <Label fx:id="pageIndicator" text="Screen 1 of 1" style="-fx-text-fill: #6c757d;"/>
        </VBox>
    </HBox>
</ScrollPane>