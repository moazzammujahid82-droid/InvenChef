<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.invenchef.controller.InventoryController"
            stylesheets="@../css/InventoryStyle.css"
            style="-fx-background-color: #f4f4f4;">

    <top>
        <HBox alignment="CENTER_LEFT"
              prefHeight="80"
              style="-fx-background-color: #174b33;">
            <padding>
                <Insets top="20" right="30" bottom="20" left="30"/>
            </padding>

            <Label text="Inventory Management"
                   style="-fx-font-size: 28px;
                          -fx-font-weight: bold;
                          -fx-text-fill: white;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="InvenChef"
                   style="-fx-font-size: 24px;
                          -fx-text-fill: #74c69d;"/>
        </HBox>
    </top>

    <left>
        <fx:include source="app-controller.fxml" />
    </left>

    <center>
        <ScrollPane fitToHeight="true"
                    fitToWidth="true"
                    hbarPolicy="AS_NEEDED"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <content>
                <HBox spacing="16">
                    <padding>
                        <Insets top="16" right="16" bottom="16" left="16"/>
                    </padding>

                    <VBox spacing="16" prefWidth="340" minWidth="300" maxWidth="380">
                        <VBox spacing="12"
                              style="-fx-background-color: white;
                                     -fx-background-radius: 8;
                                     -fx-padding: 16;
                                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,2);">

                    <Label text="Add New Ingredient"
                           style="-fx-font-size: 24px;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: #1b4332;"/>

                    <VBox spacing="10">
                        <Label text="Ingredient Name" styleClass="form-label"/>
                        <TextField fx:id="ingredientNameField"
                                   promptText="e.g. Milk"/>

                        <Label text="Quantity" styleClass="form-label"/>
                        <TextField fx:id="quantityField"
                                   promptText="e.g. 2"/>

                        <Label text="Unit" styleClass="form-label"/>
                        <ComboBox fx:id="unitCombo"
                                  maxWidth="Infinity"/>

                        <Label text="Category" styleClass="form-label"/>
                        <ComboBox fx:id="categoryCombo"
                                  maxWidth="Infinity"/>

                        <Label text="Expiry Date" styleClass="form-label"/>
                        <DatePicker fx:id="expiryDatePicker"
                                    maxWidth="Infinity"/>
                    </VBox>

                    <HBox spacing="10">
                        <Button fx:id="addIngredientBtn"
                                text="+ Add Ingredient"
                                prefHeight="45"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"
                                style="-fx-background-color: #40916c;
                                       -fx-background-radius: 8;
                                       -fx-text-fill: white;
                                       -fx-font-size: 14px;
                                       -fx-font-weight: bold;"/>

                        <Button fx:id="clearFormBtn"
                                text="Clear Form"
                                prefHeight="45"
                                HBox.hgrow="ALWAYS"
                                maxWidth="Infinity"
                                style="-fx-background-color: #dddddd;
                                       -fx-background-radius: 8;
                                       -fx-font-size: 14px;"/>
                    </HBox>
                </VBox>

                <VBox spacing="15"
                      style="-fx-background-color: white;
                             -fx-background-radius: 8;
                             -fx-padding: 16;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,2);">

                    <Label text="Inventory Stats"
                           style="-fx-font-size: 22px;
                                  -fx-font-weight: bold;"/>

                    <HBox spacing="8">
                        <VBox alignment="CENTER"
                              prefWidth="72"
                              prefHeight="70"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #40916c;
                                     -fx-background-radius: 8;">
                            <Label fx:id="totalLabel"
                                   text="0"
                                   style="-fx-text-fill: white;
                                          -fx-font-size: 16px;
                                          -fx-font-weight: bold;"/>
                        </VBox>

                        <VBox alignment="CENTER"
                              prefWidth="72"
                              prefHeight="70"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #52b788;
                                     -fx-background-radius: 8;">
                            <Label fx:id="freshLabel"
                                   text="0"
                                   style="-fx-text-fill: white;
                                          -fx-font-size: 16px;
                                          -fx-font-weight: bold;"/>
                        </VBox>

                        <VBox alignment="CENTER"
                              prefWidth="72"
                              prefHeight="70"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #fca311;
                                     -fx-background-radius: 8;">
                            <Label fx:id="expiringLabel"
                                   text="0"
                                   style="-fx-text-fill: white;
                                          -fx-font-size: 16px;
                                          -fx-font-weight: bold;"/>
                        </VBox>

                        <VBox alignment="CENTER"
                              prefWidth="72"
                              prefHeight="70"
                              HBox.hgrow="ALWAYS"
                              style="-fx-background-color: #d62828;
                                     -fx-background-radius: 8;">
                            <Label fx:id="expiredLabel"
                                   text="0"
                                   style="-fx-text-fill: white;
                                          -fx-font-size: 16px;
                                          -fx-font-weight: bold;"/>
                        </VBox>
                    </HBox>
                </VBox>
            </VBox>

                    <VBox spacing="15"
                          HBox.hgrow="ALWAYS"
                          minWidth="300"
                          style="-fx-background-color: white;
                                 -fx-background-radius: 8;
                                 -fx-padding: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 10,0,0,2);">

                <Label text="Current Inventory"
                       style="-fx-font-size: 24px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1b4332;"/>

                <HBox spacing="10">
                    <Button fx:id="allTab"
                            text="All"
                            prefWidth="82"
                            prefHeight="35"
                            style="-fx-background-color: #40916c;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;
                                   -fx-font-weight: bold;"/>

                    <Button fx:id="perishableTab"
                            text="Perishable"
                            prefWidth="92"
                            prefHeight="35"
                            style="-fx-background-color: #e9ecef;
                                   -fx-background-radius: 8;"/>

                    <Button fx:id="pantryTab"
                            text="Pantry"
                            prefWidth="82"
                            prefHeight="35"
                            style="-fx-background-color: #e9ecef;
                                   -fx-background-radius: 8;"/>

                    <Button fx:id="expiredTab"
                            text="Expired"
                            prefWidth="82"
                            prefHeight="35"
                            style="-fx-background-color: #e9ecef;
                                   -fx-background-radius: 8;"/>
                </HBox>

                <TableView fx:id="inventoryTable"
                           VBox.vgrow="ALWAYS"

                           style="-fx-background-color: transparent;
                                  -fx-border-color: transparent;
                                  -fx-table-cell-border-color: transparent;
                                  -fx-padding: 10;">
                    <columns>
                        <TableColumn fx:id="nameColumn"
                                     text="Name"
                                     prefWidth="120"
                                     style="-fx-alignment: CENTER;"/>

                        <TableColumn fx:id="qtyColumn"
                                     text="Qty"
                                     prefWidth="90"
                                     style="-fx-alignment: CENTER;"/>

                        <TableColumn fx:id="typeColumn"
                                     text="Type"
                                     prefWidth="80"
                                     style="-fx-alignment: CENTER;"/>

                        <TableColumn fx:id="expiryColumn"
                                     text="Expiry"
                                     prefWidth="90"
                                     style="-fx-alignment: CENTER;"/>

                        <TableColumn fx:id="deleteColumn"
                                     text="Delete"
                                     prefWidth="80"
                                     style="-fx-alignment: CENTER;"/>
                    </columns>
                </TableView>

                <Label fx:id="pageIndicator"
                       text="Screen 1 of 1"
                       style="-fx-text-fill: #6c757d;"/>
                    </VBox>
                </HBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
