<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.invenchef.controller.InventoryController"
            style="-fx-background-color: #f6f7f4;">
    <top>
        <VBox spacing="12" style="-fx-background-color: #ffffff; -fx-border-color: #d8ded4; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>
            <Label text="InvenChef Inventory" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #26352b;"/>
            <HBox spacing="12">
                <VBox spacing="4">
                    <Label text="Total" style="-fx-text-fill: #58645c;"/>
                    <Label fx:id="totalLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Fresh" style="-fx-text-fill: #58645c;"/>
                    <Label fx:id="freshLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Expiring" style="-fx-text-fill: #58645c;"/>
                    <Label fx:id="expiringLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                </VBox>
                <VBox spacing="4">
                    <Label text="Expired" style="-fx-text-fill: #58645c;"/>
                    <Label fx:id="expiredLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <left>
        <VBox spacing="10" prefWidth="260" style="-fx-background-color: #eef2ea; -fx-border-color: #d8ded4; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="20" right="16" bottom="20" left="16"/>
            </padding>
            <Label text="Add Ingredient" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <TextField fx:id="ingredientNameField" promptText="Name"/>
            <TextField fx:id="quantityField" promptText="Quantity and unit, e.g. 2 kg"/>
            <ComboBox fx:id="categoryCombo" maxWidth="Infinity"/>
            <DatePicker fx:id="expiryDatePicker" promptText="Expiry date" maxWidth="Infinity"/>
            <HBox spacing="8">
                <Button fx:id="addIngredientBtn" text="Add" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                        style="-fx-background-color: #4a7c5e; -fx-text-fill: white;"/>
                <Button fx:id="clearFormBtn" text="Clear" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <HBox spacing="8">
                <Button fx:id="allTab" text="All"/>
                <Button fx:id="perishableTab" text="Perishable"/>
                <Button fx:id="pantryTab" text="Pantry"/>
                <Button fx:id="expiredTab" text="Expired"/>
            </HBox>
            <TableView fx:id="inventoryTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Name"/>
                    <TableColumn fx:id="qtyColumn" text="Quantity"/>
                    <TableColumn fx:id="typeColumn" text="Type"/>
                    <TableColumn fx:id="expiryColumn" text="Expiry"/>
                    <TableColumn fx:id="deleteColumn" text=""/>
                </columns>
            </TableView>
            <Label fx:id="pageIndicator" text="Screen 1 of 1" style="-fx-text-fill: #58645c;"/>
        </VBox>
    </center>
</BorderPane>
